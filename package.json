{
  "name": "fifa-t3db",
  "version": "0.0.0",
  "author": {
    "name": "Dominik Hladík",
    "email": "dominik.hladik@seznam.cz",
    "url": "https://github.com/Celtian"
  },
  "license": "MIT",
  "private": false,
  "description": "Portable TypeScript reader and editor for FIFA PC t3db databases",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "SUPPORT.md"
  ],
  "scripts": {
    "validate": "bun run lint && bun run typecheck && bun run test:coverage && bun run build",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "bun run prepare-dist",
    "changelog": "auto-changelog",
    "demo": "bun demo.ts",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "prepare": "if test -d .git && test -x node_modules/.bin/husky; then node_modules/.bin/husky; fi",
    "prepack": "bun run build",
    "postversion": "git push && git push --follow-tags",
    "prepare-dist": "bun scripts/prepare-dist.ts",
    "gpr:setup": "bun scripts/gpr-setup.ts",
    "publish:beta": "bun install --frozen-lockfile && bun run validate && npm publish --folder dist --tag beta",
    "release:beta": "bun pm version prerelease --preid beta --message \"chore(update): prerelease %s β\"",
    "release:patch": "git checkout master && bun pm version patch --message \"chore(update): patch release %s 🐛\"",
    "release:minor": "git checkout master && bun pm version minor --message \"chore(update): release %s 🚀\"",
    "release:major": "git checkout master && bun pm version major --message \"chore(update): major release %s 💥\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "version": "auto-changelog -p && git add CHANGELOG.md"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts}": "eslint --fix --max-warnings=0"
  },
  "dependencies": {
    "fast-xml-parser": "^5.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.23",
    "auto-changelog": "^2.6.0",
    "eslint": "^10.7.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "quick-commitlint": "^0.0.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "auto-changelog": {
    "remote": "none",
    "commitUrl": "https://github.com/Celtian/fifa-t3db/commit/{id}",
    "issueUrl": "https://github.com/Celtian/fifa-t3db/issues/{id}",
    "mergeUrl": "https://github.com/Celtian/fifa-t3db/pull/{id}",
    "compareUrl": "https://github.com/Celtian/fifa-t3db/compare/{from}...{to}",
    "template": "keepachangelog",
    "unreleased": true,
    "commitLimit": false
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24",
    "npm": "please-use-bun"
  },
  "keywords": [
    "fifa",
    "fifa-16",
    "t3db",
    "database",
    "huffman",
    "typescript",
    "browser"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
